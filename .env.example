# Copy this file to .env and fill in your key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model used by the triage engine
TRIAGE_MODEL=claude-sonnet-4-6

# Confidence threshold (0-100). Below this, alerts are always routed to a human
# even if severity is low/medium.
AUTO_CLOSE_CONFIDENCE_THRESHOLD=85

# Path to the SQLite database file
DATABASE_PATH=./soc_console.db
